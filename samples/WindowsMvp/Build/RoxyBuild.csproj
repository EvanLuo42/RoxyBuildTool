<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>14.0</LangVersion>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <RestorePackagesPath>../../../artifacts/sample-packages</RestorePackagesPath>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="RoxyBuildTool" Version="$(Version)" />
    <PackageReference Include="RoxyBuildTool.Platforms.Windows" Version="$(Version)" />
    <PackageReference Include="RoxyBuildTool.Generators.VisualStudio" Version="$(Version)" />
    <PackageReference Include="RoxyBuildTool.Generators.CompilationDatabase" Version="$(Version)" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="../**/*.Module.cs" Link="Modules/%(RecursiveDir)%(Filename)%(Extension)" />
    <None Remove="packages.lock.json" />
  </ItemGroup>
</Project>
